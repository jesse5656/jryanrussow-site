#!/usr/bin/env bash

# BEGIN REPOSITORY GOVERNANCE ENTRY
REPOSITORY_ROOT="$(git rev-parse --show-toplevel)"
python3 "$REPOSITORY_ROOT/scripts/governance/governance_engine.py" --staged
# END REPOSITORY GOVERNANCE ENTRY


echo "Running governance checks..."

if [ "${ALLOW_ARCHITECTURE_CHANGE:-}" = "1" ]; then
  echo "Governance override approved."
  exit 0
fi

protected_patterns='(^START-HERE\.md$|^OPERATING-PLAN\.md$|^docs/discipline/|^docs/operations/|^docs/governance/|^publish/mkdocs\.yml$)'

staged_protected="$(
  git diff --cached --name-only | grep -E "$protected_patterns" || true
)"

if [ -n "$staged_protected" ]; then
  echo
  echo "BLOCKED: Governance/protected files are staged:"
  echo "$staged_protected"
  echo
  echo "Reason:"
  echo "Governance, architecture, operating procedure, or protected repository-control files were staged."
  echo
  echo "If this change is intentional:"
  echo "1. Review the diff:"
  echo "   git diff --cached"
  echo
  echo "2. Confirm the ACP/OCP or explicit approval."
  echo
  echo "3. Commit with:"
  echo "   ALLOW_ARCHITECTURE_CHANGE=1 git commit -m \"your message\""
  echo
  echo "If this was accidental:"
  echo "   git restore --staged <file>"
  echo "   git restore <file>"
  echo
  exit 1
fi

echo "Governance checks passed."
